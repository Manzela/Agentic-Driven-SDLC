# plane.env.template — copy to `plane.env` and fill the secrets before first boot.
#   cp plane.env.template plane.env  &&  $EDITOR plane.env
# `plane.env` itself is gitignored (it holds secrets); this template is committed.
#
# Tuned for the public origin https://plane.autonomous-agent.dev behind a
# Cloudflare Tunnel (TLS terminated at the edge; Plane's proxy serves plain HTTP
# on localhost:80, which cloudflared forwards to). See docs/deploy/PLANE_EDGE_DEPLOY.md.

# ── Release channel ──────────────────────────────────────────────────────────
APP_RELEASE=stable

# ── Public origin (MUST be set before first boot: drives CORS / cookies / URLs)
APP_DOMAIN=plane.autonomous-agent.dev
WEB_URL=https://plane.autonomous-agent.dev
CORS_ALLOWED_ORIGINS=https://plane.autonomous-agent.dev

# ── Proxy (Caddy). Edge does TLS, so serve plain HTTP on :80 and leave ACME off.
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_CA=
CERT_ACME_DNS=
FILE_SIZE_LIMIT=5242880

# ── Secrets — REPLACE ALL of these (do NOT ship the compose defaults to prod) ─
# Generate each with:  openssl rand -hex 32   (or `python3 -c "import secrets;print(secrets.token_hex(32))"`)
SECRET_KEY=__REPLACE_WITH_openssl_rand_hex_32__
LIVE_SERVER_SECRET_KEY=__REPLACE_WITH_openssl_rand_hex_32__

# ── Postgres ─────────────────────────────────────────────────────────────────
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=__REPLACE_strong_db_password__
POSTGRES_DB=plane
POSTGRES_PORT=5432
# DATABASE_URL — REQUIRED in plane.env. A Postgres connection URL for user
# POSTGRES_USER / password POSTGRES_PASSWORD (above) against host plane-db,
# database "plane". Compose's built-in default assumes the password is "plane";
# if you change POSTGRES_PASSWORD you MUST set DATABASE_URL here to match it.
# (Left unset here so no inline credential ships in version control.)
# DATABASE_URL=

# ── Redis / Valkey ───────────────────────────────────────────────────────────
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=__REPLACE_strong_mq_password__
RABBITMQ_VHOST=plane
# AMQP_URL — REQUIRED in plane.env. A RabbitMQ connection URL for user
# RABBITMQ_USER / password RABBITMQ_PASSWORD (above) against host plane-mq,
# port 5672, vhost "plane". Compose's built-in default assumes the password is
# "plane"; if you change RABBITMQ_PASSWORD you MUST set AMQP_URL here to match.
# (Left unset here so no inline credential ships in version control.)
# AMQP_URL=

# ── Object storage (MinIO, in-stack) ─────────────────────────────────────────
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=__REPLACE_minio_access_key__
AWS_SECRET_ACCESS_KEY=__REPLACE_minio_secret_key__
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ENDPOINT_SSL=0

# ── App tuning ───────────────────────────────────────────────────────────────
DEBUG=0
GUNICORN_WORKERS=1
API_KEY_RATE_LIMIT=60/minute
WEBHOOK_ALLOWED_IPS=
WEBHOOK_ALLOWED_HOSTS=
