# credentials.env.template — copy to `credentials.env` after the Plane instance is
# up and you've created a workspace + project + API token (see deploy.sh step 4).
#   cp credentials.env.template credentials.env  &&  $EDITOR credentials.env
# `credentials.env` is gitignored (it holds an API key); this template is committed.
#
# Consumed by plane-integration/provision_plane.py and reorg_plane.py to
# materialize the 8 epics / 49 stories / 186 tasks / 7 cycles from
# docs/plane/plane_backlog.json into the live instance.

# Public REST base for the instance (note the /api/v1 suffix the agents use).
PLANE_API_BASE=https://plane.autonomous-agent.dev/api/v1

# Workspace slug you created at first-run (the runbook uses "ascp").
PLANE_WORKSPACE_SLUG=ascp

# Project UUID — copy from the project's URL or Settings after you create it.
PLANE_PROJECT_ID=__REPLACE_with_project_uuid__

# API token — Workspace Settings → API tokens → "Add API token".
PLANE_API_KEY=__REPLACE_with_api_token__
